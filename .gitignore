# ─── Node / npm ───────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json        # keep if you want reproducible installs; delete this line if so

# ─── Vite / Frontend build ────────────────────────────────────
frontend/dist/
frontend/.cache/
frontend/.vite/

# ─── Environment & secrets ────────────────────────────────────
.env
.env.local
.env.*.local

# ─── Python / Selenium tests ──────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.venv/
venv/
*.egg-info/

# WebDriver manager cache (downloaded ChromeDriver binaries)
.wdm/

# ─── OS generated ─────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─── IDE / Editor ─────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.user
*.swp
*.swo

# ─── Logs ─────────────────────────────────────────────────────
logs/
*.log

# ─── Misc ─────────────────────────────────────────────────────
coverage/
.nyc_output/
